@page "/"
@using System.Collections.Specialized
@using System.Windows
@using FieldToFortune.Model
@using FieldToFortune.Service
@inject GameState GameState
@inject TradingService TradingService
@inject NavigationManager NavigationManager



<div class="menu-page">

    <div class="menu-card">

        <!-- Title -->
        <div class="menu-header">
            <h1 class="menu-title">Field to Fortune</h1>
            <p class="menu-tagline">Set off on the road to riches!</p>
        </div>
        
        <!-- Rules -->
        <button class="info-icon" @onclick="ToggleRules" title="Game Rules">
            ⓘ
        </button>
        
        @if (_showRules)
        {
            <div class="rules-overlay" @onclick="ToggleRules">
                <div class="rules-content" @onclick:stopPropagation="true">
                    <button class="close-button" @onclick="ToggleRules">&times;</button>
                
                    <h2>◈ Rules</h2>
                    <div class="rules-grid">
                        <div class="rule-item">
                            You are a farmer turned trader, trying to grow your savings by investing in the agricultural markets.
                        </div>
                        <div class="rule-item">
                            Each in-game turn represents one month. Price movements are modeled on real historical volatility.
                        </div>
                        <div class="rule-item">
                            Every three months, look out for news headlines. These are signals for upcoming events that might (or might not) shift the market next turn.
                        </div>
                        <div class="rule-item">
                            Try to outperform the historical trend. If your total net worth drops below 50% of your starting funds, you'll be forced to retire from the market.
                            </div>
                    </div>
                
                    <div class="hint">
                        <p><em>Tip: Commodities on the market are listed in rising order of volatility.</em></p>
                    </div>
                </div>
            </div>
        }

        <!-- New game form -->
        @if (!GameState.HasStarted || _inConfiguration || GameState.IsFinished)
        {
            <div class="menu-form">
                <div class="menu-field">
                    <label class="menu-label">Your name</label>
                    <input class="menu-input" type="text" @bind="_playerName" @bind:event="oninput"
                           placeholder="Enter your name" maxlength="20"
                           @onkeydown="HandleNameInput"/>
                </div>

                <div class="menu-field">
                    <label class="menu-label">Difficulty</label>
                    <div class="difficulty-selector">
                        @foreach (var diff in _difficulties)
                        {
                            <button class="diff-btn @(_selectedDifficulty == diff ? "diff-btn--active" : "")"
                                    @onclick="() => _selectedDifficulty = diff">
                                <span class="diff-btn__name">@diff.Name</span>
                                <span class="diff-btn__target">Target: $ @diff.Target</span>
                            </button>
                        }
                    </div>
                </div>

                @if (_error != null)
                {
                    <p class="menu-error">@_error</p>
                }

                <button class="btn btn--primary btn--full btn--large" @onclick="OnStartGame">
                    Play ▶
                </button>
            </div>
        }

        else
        {
            <!-- Game in progress recap -->
            <div class="menu-recap">
                <p class="menu-recap__label">Game in progress</p>

                <div class="recap-grid">
                    <div class="recap-item">
                        <span class="recap-item__label">Player</span>
                        <span class="recap-item__value">@GameState.Player.Name</span>
                    </div>
                    <div class="recap-item">
                        <span class="recap-item__label">Difficulty</span>
                        <span class="recap-item__value">@_currentDifficultyName</span>
                    </div>
                    <div class="recap-item">
                        <span class="recap-item__label">Target</span>
                        <span class="recap-item__value">$ @GameState.WinningNetWorth</span>
                    </div>
                    <div class="recap-item">
                        <span class="recap-item__label">Turn</span>
                        <span class="recap-item__value">@Math.Min(GameState.CurrentTurn, GameState.NbTurns) / @GameState.NbTurns</span>
                    </div>
                </div>

                <div class="menu-recap__actions">
                    <button class="btn btn--primary btn--full" @onclick='() => NavigationManager.NavigateTo("market")'>
                        Resume Game
                    </button>
                    <button class="btn btn--outline btn--full" @onclick="OnNewGame">
                        New Game
                    </button>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private bool _inConfiguration;
    private record Difficulty(string Name, double Target);

    private readonly List<Difficulty> _difficulties = new()
    {
        new("Easy",   1.2*PlayerStats.StartCash),
        new("Medium", 1.5*PlayerStats.StartCash),
        new("Hard",   1.8*PlayerStats.StartCash),
    };

    private string _playerName = "";
    private Difficulty _selectedDifficulty = null!;
    private string? _error;
    private string _currentDifficultyName = "Medium";
    private bool _showRules;

    protected override void OnInitialized()
    {
        _playerName = GameState.Player.Name;
        _selectedDifficulty = _difficulties[1]; // Default difficulty is medium
        if (GameState.HasStarted)
            _currentDifficultyName = GetDifficultyName(GameState.WinningNetWorth);
    }
    
    private void ToggleRules()
    {
        _showRules = !_showRules;
    }

    private void OnStartGame()
    {
        if (string.IsNullOrWhiteSpace(_playerName))
        {
            _error = "Please enter your name.";
            return;
        }
        _error = null;
        _currentDifficultyName = _selectedDifficulty.Name;

        // Reset game state in place
        GameState.Reset(new Player(_playerName), _selectedDifficulty.Target);
        GameState.FirstGame = false;
        GameState.HasStarted = true;
        GameState.NotifyStateChanged();
        NavigationManager.NavigateTo("market");
    }

    private void OnNewGame()
    {
        _inConfiguration = true;
        _playerName = GameState.Player.Name;
        _selectedDifficulty = _difficulties[1];
    }

    private string GetDifficultyName(double target) => target switch
    {
        1.2*PlayerStats.StartCash => "Easy",
        1.5*PlayerStats.StartCash => "Medium",
        1.8*PlayerStats.StartCash => "Hard",
        _ => "Custom"
    };

    private void HandleNameInput(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") OnStartGame();
    }
}