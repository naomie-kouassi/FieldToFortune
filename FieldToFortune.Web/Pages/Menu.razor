@page "/menu"
@using FieldToFortune.Model
@using FieldToFortune.Service
@inject GameState GameState
@inject TradingService TradingService
@inject NavigationManager NavigationManager

<!-- ═══════════════════════════════════════════════════════
     MENU.RAZOR — Start menu / new game
═══════════════════════════════════════════════════════ -->

<div class="menu-page">

    <div class="menu-card">

        <!-- Title -->
        <div class="menu-header">
            <h1 class="menu-title">Field to Fortune</h1>
            <p class="menu-tagline">Set off on the road to riches!</p>
        </div>

        @if (!GameState.HasStarted || GameState.InConfiguration)
        {
            <!-- New game form -->
            <div class="menu-form">
                <div class="menu-field">
                    <label class="menu-label">Your name</label>
                    <input class="menu-input" type="text" @bind="_playerName"
                           placeholder="Enter your name" maxlength="20" />
                </div>

                <div class="menu-field">
                    <label class="menu-label">Difficulty</label>
                    <div class="difficulty-selector">
                        @foreach (var diff in _difficulties)
                        {
                            <button class="diff-btn @(_selectedDifficulty == diff ? "diff-btn--active" : "")"
                                    @onclick="() => _selectedDifficulty = diff">
                                <span class="diff-btn__name">@diff.Name</span>
                                <span class="diff-btn__target">Target: $ @diff.Target</span>
                            </button>
                        }
                    </div>
                </div>

                @if (_error != null)
                {
                    <p class="menu-error">@_error</p>
                }

                <button class="btn btn--primary btn--full btn--large" @onclick="OnStartGame">
                    Play ▶
                </button>
            </div>
        }
        else
        {
            <!-- Game in progress recap -->
            <div class="menu-recap">
                <p class="menu-recap__label">Game in progress</p>

                <div class="recap-grid">
                    <div class="recap-item">
                        <span class="recap-item__label">Player</span>
                        <span class="recap-item__value">@GameState.Player.Name</span>
                    </div>
                    <div class="recap-item">
                        <span class="recap-item__label">Difficulty</span>
                        <span class="recap-item__value">@_currentDifficultyName</span>
                    </div>
                    <div class="recap-item">
                        <span class="recap-item__label">Target</span>
                        <span class="recap-item__value">$ @GameState.WinningNetWorth</span>
                    </div>
                    <div class="recap-item">
                        <span class="recap-item__label">Turn</span>
                        <span class="recap-item__value">@GameState.CurrentTurn / @GameState.NbTurns</span>
                    </div>
                </div>

                <div class="menu-recap__actions">
                    <button class="btn btn--primary btn--full" @onclick='() => NavigationManager.NavigateTo("/market")'>
                        Resume Game
                    </button>
                    <button class="btn btn--outline btn--full" @onclick="OnNewGame">
                        New Game
                    </button>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private record Difficulty(string Name, double Target);

    private readonly List<Difficulty> _difficulties = new()
    {
        new("Easy",   1200),
        new("Medium", 1500),
        new("Hard",   2000),
    };

    private string _playerName = "";
    private Difficulty _selectedDifficulty;
    private string? _error;
    private string _currentDifficultyName = "Medium";

    protected override void OnInitialized()
    {
        _selectedDifficulty = _difficulties[1]; // Medium default
        // If a game is already running show recap
        if (GameState.HasStarted)
            _currentDifficultyName = GetDifficultyName(GameState.WinningNetWorth);
    }

    private void OnStartGame()
    {
        if (string.IsNullOrWhiteSpace(_playerName))
        {
            _error = "Please enter your name.";
            return;
        }
        _error = null;
        _currentDifficultyName = _selectedDifficulty.Name;

        // Reset game state in place
        GameState.Reset(new Player(_playerName), _selectedDifficulty.Target);

        // Re-init portfolio with all commodities
        foreach (var commodity in GameState.Market.Commodities)
            GameState.Player.Portfolio.AddCommodity(commodity, 0);

        GameState.HasStarted = true;
        GameState.NotifyStateChanged();
        NavigationManager.NavigateTo("/market");
    }

    private void OnNewGame()
    {
        GameState.HasStarted = false;
        _playerName = "";
        _selectedDifficulty = _difficulties[1];
    }

    private string GetDifficultyName(double target) => target switch
    {
        1200 => "Easy",
        1500 => "Medium",
        2000 => "Hard",
        _ => "Custom"
    };
}