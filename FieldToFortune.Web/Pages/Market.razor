@page "/market"
@using System.Net.NetworkInformation
@using FieldToFortune.Model
@using FieldToFortune.Service
@inject GameState GameState
@inject TradingService TradingService
@inject NavigationManager NavigationManager
@inject SaveService SaveService


<!-- ═══════════════════════════════════════════════════════════
     HOME.RAZOR — Main trading page
     Layout :
       [Order Panel | Chart + Asset Selector]
     
     Theme is controlled by a CSS class on <body> toggled
     by the ThemeToggle button in the top bar.
═══════════════════════════════════════════════════════════ -->


<div class="market-page">

    <!-- ── HEADER ──────────────────────────────────────────── -->
    <div class="page-header">
        <h1 class="page-title">Market</h1>
    </div>

    <!-- ── TOP BAR ─────────────────────────────────────────── -->
    <header class="top-bar">
        <div class="top-bar__left">
            <span class="stat">Turn <strong>@Math.Min(GameState.CurrentTurn, GameState.NbTurns)</strong> / @GameState.NbTurns</span>
        </div>
        <div class="top-bar__center">
            <span class="stat">Cash $ <strong>@GameState.Player.Cash.ToString("F2")</strong></span>
            <span class="stat @(GameState.Player.Progession(GameState.Market) >= 0 ? "stat--positive" : "stat--negative")">
                Net Worth $ <strong>@GameState.Player.NetWorth(GameState.Market).ToString("F2")</strong>
                <small>(@(GameState.Player.Progession(GameState.Market) >= 0 ? "+" : "")@((GameState.Player.Progession(GameState.Market) * 100).ToString("F1"))%)</small>
            </span>
            <span class="stat">Target $ <strong>@GameState.WinningNetWorth</strong></span>
        </div>
        <div class="top-bar__right">
            <!-- Next turn -->
            <button class="btn btn--primary" @onclick="OnNextTurn" disabled="@GameState.IsFinished">
                Next Turn ▶
            </button>
        </div>
    </header>

    <!-- ── HEADLINES BANNER (shown when a market event occurs) ─── -->
    @if (GameState.Market.LastNews != null)
    {
        <div class="event-banner">
            [NEWS FLASH] @GameState.Market.LastNews.ToString()
        </div>
    }

    <!-- ── MAIN CONTENT ──────────────────────────────────────── -->
    <main class="trading-layout">

        <!-- LEFT : Order Panel -->
        <aside class="order-panel">
            <h2 class="panel-title">Place Order</h2>

            <!-- Selected asset info -->
            <div class="selected-asset">
                <span class="selected-asset__name">@_selectedCommodity.Name</span>
                <span class="selected-asset__price">$ @_selectedCommodity.Price.ToString("F2")</span>
                <span class="variation @(_selectedCommodity.Variation >= 0 ? "variation--up" : "variation--down")">
                    @(_selectedCommodity.Variation >= 0 ? "▲" : "▼")
                    @Math.Abs(_selectedCommodity.Variation * 100).ToString("F1")%
                </span>
            </div>

            <!-- Order type tabs -->
            <div class="order-tabs">
                <button class="order-tab @(_orderType == "buy" ? "order-tab--active" : "")"
                        @onclick='() => _orderType = "buy"'>Buy</button>
                <button class="order-tab @(_orderType == "sell" ? "order-tab--active" : "")"
                        @onclick='() => _orderType = "sell"'>Sell</button>
                <button class="order-tab @(_orderType == "call" ? "order-tab--active" : "")"
                        @onclick='() => _orderType = "call"'>Call Option</button>
            </div>

            <!-- Buy / Sell form -->
            @if (_orderType == "buy" || _orderType == "sell")
            {
                <div class="order-form">
                    <label class="form-label"> @($"Quantity \t ({GameState.Player.Portfolio.Quantity(_selectedCommodity.Name)} in portfolio)")</label>
                    <input class="form-input" type="number" min="1" @bind="_quantity"
                           @onkeydown="HandleIntegerKeyDown" 
                           @onkeydown:preventDefault="shouldBlock"/>

                    <div class="order-cost">
                        Total : $ <strong>@((_selectedCommodity.Price * _quantity).ToString("F2"))</strong>
                    </div>

                    <button class="btn @(_orderType == "buy" ? "btn--buy" : "btn--sell") btn--full"
                            @onclick="OnPlaceOrder">
                        @(_orderType == "buy" ? "Buy" : "Sell") @_selectedCommodity.Name
                    </button>
                </div>
            }

            <!-- Call option form -->
            @if (_orderType == "call")
            {
                <div class="order-form">
                    <label class="form-label">Strike Price ($)</label>
                    <input class="form-input" type="number" step="0.01"
                           @bind="_strikePrice"
                           @onkeydown="HandleDoubleKeyDown" 
                           @onkeydown:preventDefault="shouldBlock"
                           />

                    <label class="form-label">Expiry (turns)</label>
                    <input class="form-input" type="number" min="1" max="5"
                           @bind="_expiryTurns"
                           @onkeydown="HandleIntegerKeyDown" 
                           @onkeydown:preventDefault="shouldBlock"/>

                    <label class="form-label">Quantity</label>
                    <input class="form-input" type="number" min="1" @bind="_quantity"
                           @onkeydown="HandleIntegerKeyDown" 
                           @onkeydown:preventDefault="shouldBlock"/>

                    <div class="order-cost">
                        Premium : $ <strong>@_callPremium.ToString("F2")</strong>
                    </div>

                    <button class="btn btn--call btn--full" @onclick="OnBuyCall">
                        Buy Call Option
                    </button>
                </div>
            }

            <!-- Error / success message -->
            @if (_message != null)
            {
                <div class="order-message @(_messageIsError ? "order-message--error" : "order-message--success")">
                    @_message
                </div>
            }

            <!-- Active options summary -->
            @if (GameState.Player.Calls.Any())
            {
                <div class="active-options">
                    <h3 class="panel-subtitle">Active Options</h3>
                    @foreach (var option in GameState.Player.Calls.Keys)
                    {
                        @if (option.Underlying == _selectedCommodity)
                        {
                            <div class="option-card">
                                <span>CALL @option.Underlying.Name @GameState.Player.Calls[option]x</span>
                                <span>Strike = $@option.StrikePrice.ToString("F2")</span>
                                <span>Expires in @option.Expiry turns</span>
                                <span class="option-card__payoff">
                                    Payoff : $@option.Payoff.ToString("F2")
                                </span>
                            </div>
                        }
                    }
                </div>
            }
        </aside>

        <!-- RIGHT : Chart + Asset Selector -->
        <section class="chart-section">

            <!-- Price chart -->
            <div class="chart-container">
                <ApexChart TItem="PricePoint"
                           Height="@("100%")"
                           @key="_selectedCommodity.Name"
                           Title="@($"Price History of {_selectedCommodity.Name} ")"
                           Options="_chartOptions"
                           @ref="_chart">
                    <ApexPointSeries TItem="PricePoint"
                                     Items="_priceHistory"
                                     Name="Price"
                                     SeriesType="SeriesType.Line"
                                     XValue="@(p => p.Turn)"
                                     YValue="@(p => (decimal)p.Price)"/>
                </ApexChart>
            </div>

            <!--f Asset selector buttons -->
            <div class="asset-selector">
                @foreach (var commodity in GameState.Market.Commodities)
                {
                    <button class="asset-btn @(commodity == _selectedCommodity ? "asset-btn--active" : "")
                                             @(!commodity.IsUnlocked ? "asset-btn--locked" : "")"
                            @onclick="() => OnSelectCommodity(commodity)"
                            disabled="@(!commodity.IsUnlocked)">
                        <span class="asset-btn__name">@commodity.Name</span>
                        <span class="asset-btn__price">@commodity.Price.ToString("F2")$</span>
                        <span class="asset-btn__var @(commodity.Variation >= 0 ? "var--up" : "var--down")">
                            @(commodity.Variation >= 0 ? "+" : "")@((commodity.Variation * 100).ToString("F1"))%
                        </span>
                        @if (!commodity.IsUnlocked)
                        {
                            <span class="asset-btn__lock">🔒 Get to $ @commodity.UnlockThreshold Net Worth</span>
                        }
                    </button>
                }
            </div>

        </section>
    </main>

    <!-- ── END OF GAME OVERLAY ──────────────────────────────── -->
    @if (GameState.IsFinished)
    {
        <div class="endgame-overlay">
            <div class="endgame-card">
                <h1 class="endgame-title @(GameState.HasWon ? "endgame-title--win" : "endgame-title--loss")">
                    @(GameState.HasWon ? "Victory!" : "Game Over")
                </h1>
                <p class="endgame-stat">
                    Final net worth : <strong>@GameState.Player.NetWorth(GameState.Market).ToString("F2") $</strong>
                </p>
                <p class="endgame-stat">
                    Performance : @(GameState.Player.Profits(GameState.Market) >= 0 ? "+" : "-") $<strong>@(Math.Abs(GameState.Player.Profits(GameState.Market)).ToString("F2"))</strong>
                </p>
                <button class="btn btn--primary" @onclick="OnRestart">Play Again</button>
            </div>
        </div>
    }

</div>

@code {
    // ── State ────────────────────────────────────────────────
    private Commodity _selectedCommodity = null!;
    private string _orderType = "buy";
    private int _quantity = 1;
    private double _strikePrice;
    private int _expiryTurns = 3;
    private string? _message;
    private bool _messageIsError;

    // Chart
    private ApexChart<PricePoint>? _chart;
    private List<PricePoint> _priceHistory = new();
    private ApexChartOptions<PricePoint> _chartOptions = new();

    // ── Computed ─────────────────────────────────────────────
    private double _callPremium =>
        _quantity * TradingService.ComputePremium(_selectedCommodity, _strikePrice, _expiryTurns);

    // ── Lifecycle ────────────────────────────────────────────
    protected override void OnInitialized()
    {
        _selectedCommodity = GameState.Market.Commodities.FirstOrDefault(c => c.Name == "Wheat") 
                             ?? GameState.Market.Commodities.First();
        OnSelectCommodity(_selectedCommodity);
        ConfigureChart();
        GameState.OnThemeChanged += HandleThemeChange;
    }
    
    private void HandleThemeChange()
    {
        _chartOptions.Theme.Mode = GameState.IsDarkMode ? Mode.Dark : Mode.Light;
        _chartOptions.Tooltip.Theme = GameState.IsDarkMode ? Mode.Dark : Mode.Light;
        
        if (_chart != null)
        {
            _ = _chart.UpdateOptionsAsync(false, true, false);
        }
        
        StateHasChanged(); // Force the chart to re-render with new colors
    }
    
    public void Dispose()
    {
        GameState.OnThemeChanged -= HandleThemeChange;
    }

    // ── Event Handlers ───────────────────────────────────────
    private void OnSelectCommodity(Commodity commodity)
    {
        _selectedCommodity = commodity;
        _strikePrice = double.Round(commodity.Price);
        UpdatePriceHistory();
        _message = null;
    }

    private void OnPlaceOrder()
    {
        bool success = _orderType == "buy"
            ? TradingService.BuyCommodity(GameState.Player, _selectedCommodity, _quantity, GameState.CurrentTurn) != null
            : TradingService.SellCommodity(GameState.Player, _selectedCommodity, _quantity, GameState.CurrentTurn) != null;

        if (success)
        {
            ShowMessage($"{(_orderType == "buy" ? "Bought" : "Sold")} {_quantity}x {_selectedCommodity.Name}", false);
        }
        else
        {
            ShowMessage(_orderType == "buy" ? "Insufficient funds." : "Not enough holdings.", true);
        }
    }

    private void OnBuyCall()
    {
        var option = TradingService.BuyCall(
            GameState.Player, _selectedCommodity, _strikePrice, _expiryTurns, _quantity, GameState.CurrentTurn);

        if (option != null)
            ShowMessage($"Call option purchased (premium ${_callPremium:F2})", false);
        else
            ShowMessage("Insufficient funds for this option.", true);
        
        GameState.NotifyStateChanged();;
    }

    private async Task OnNextTurn()
    {
        GameState.NextTurn();
        if (GameState.CurrentTurn > GameState.NbTurns) return;
        
        _selectedCommodity = GameState.Market.Commodities
            .FirstOrDefault(c => c.Name == _selectedCommodity.Name) ?? _selectedCommodity;
        
        await SaveService.SaveGame(GameState);

        Console.WriteLine($"Selected commodity is: {_selectedCommodity.Name}");
            
        var newPrice = GameState.PriceProvider.GetPrice(_selectedCommodity.Name, GameState.CurrentTurn-1);
    
        // 2. Add just the single new point to your existing list
        _priceHistory.Add(new PricePoint(GameState.CurrentTurn, newPrice));

        // 3. Tell ApexCharts to "Animate" to the new point
        if (_chart != null)
        {
            _ = _chart.UpdateSeriesAsync(true);
        }

        _message = null;
    }
    
    private void OnRestart()
    {
        // Re-inject a fresh GameState
        NavigationManager.NavigateTo("/menu", forceLoad: true);
    }



    // ── Helpers ──────────────────────────────────────────────
    private void UpdatePriceHistory()
    {
        // Rebuild price history for the selected commodity up to current turn

        var priceList = GameState.PriceProvider.GetFirstPrices(_selectedCommodity.Name, GameState.CurrentTurn);
        var history = new List<PricePoint>();
        var turn = 1;
        foreach (var price in priceList)
        {
            history.Add(new PricePoint(turn, price));
            turn++;
        }

        _priceHistory = history;
    }

    private void ShowMessage(string text, bool isError)
    {
        _message = text;
        _messageIsError = isError;
    }

    private void ConfigureChart()
    {
        _chartOptions = new ApexChartOptions<PricePoint>()
        {
            Chart = new Chart
            {
                Background = "transparent",
                Toolbar = new Toolbar { Show = false },
                Animations = new Animations { 
                    Enabled = true, 
                    Speed=800,
                    Easing = Easing.Linear,
                    AnimateGradually = new AnimateGradually{ Enabled = true }
                    
                }
            },
            Stroke = new Stroke { Curve = Curve.Straight, Width = new List<int> { 2 } },
            Grid = new Grid { BorderColor = "rgba(255,255,255,0.08)" },
            
            Theme = new Theme{ Mode = GameState.IsDarkMode ? Mode.Dark : Mode.Light},
            
            Tooltip = new Tooltip { Theme = GameState.IsDarkMode ? Mode.Dark : Mode.Light },
        
            Xaxis = new XAxis { Title = new AxisTitle { Text = "Turn" } },
        
            Yaxis = new List<YAxis>
            {
                new YAxis
                {
                    Title = new AxisTitle {  Text = "Price ($)" },
                    Labels = new YAxisLabels
                    {
                        Formatter = "function(val) { return val.toFixed(2) + '$' }"
                    }
                }
            }
        };
    }
    
    
    private bool _isInitialLoad = true;

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            // Give it a tiny delay to ensure the first 'static' draw is done
            _isInitialLoad = false;
        }
    }
    
    private bool shouldBlock = false;

    private void HandleIntegerKeyDown(KeyboardEventArgs e)
    {
        // Define the "Illegal" keys
        var forbidden = new[] { "-", "e", "E", "+", ".",",","^","`" };
        
        // If the key is in our forbidden list, set shouldBlock to true
        shouldBlock = forbidden.Contains(e.Key);
    }
    
    private void HandleDoubleKeyDown(KeyboardEventArgs e)
    {
        // Define the "Illegal" keys
        var forbidden = new[] { "-", "e", "E", "+",",","^","`" };
        
        // If the key is in our forbidden list, set shouldBlock to true
        shouldBlock = forbidden.Contains(e.Key);
    }

    // Simple record for chart data points
    private record PricePoint(int Turn, double Price);
}
