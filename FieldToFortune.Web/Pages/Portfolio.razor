@page "/portfolio"
@using FieldToFortune.Model
@using FieldToFortune.Service
@inject GameState GameState
@inject TradingService TradingService
@inject SaveService SaveService



<div class="portfolio-page">

    <!-- -- Header -------------------------------------------- -->
    <div class="page-header">
        <h1 class="page-title">Portfolio</h1>
        <div class="portfolio-summary">
            <div class="summary-card">
                <span class="summary-card__label">Cash</span>
                <span class="summary-card__value">$ @GameState.Player.Cash.ToString("F2")</span>
            </div>
            <div class="summary-card">
                <span class="summary-card__label">Holdings Value</span>
                <span class="summary-card__value">$ @HoldingsValue.ToString("F2")</span>
            </div>
            <div class="summary-card summary-card--accent">
                <span class="summary-card__label">Net Worth</span>
                <span class="summary-card__value">$ @NetWorth.ToString("F2")</span>
            </div>
            <div class="summary-card @(Progression>= 0 ? "summary-card--positive" : "summary-card--negative")">
                <span class="summary-card__label">Performance</span>
                <span class="summary-card__value">
                    @(Progression >= 0 ? "+" : "")@((Progression*100).ToString("F1"))%
                </span>
            </div>
        </div>
    </div>

    <!-- -- Holding table ----------------------------------- -->
    <section class="portfolio-section">
        <h2 class="section-title">Holdings</h2>

        @if (!Holdings.Any())
        {
            <p class="empty-state">You don't own any commodities yet. Head to the market!</p>
        }
        else
        {
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Commodity</th>
                        <th class="text-center">Quantity</th>
                        <th class="text-center">Current Price</th>
                        <th class="text-center">Value</th>
                        <th class="text-center">Variation</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var commodity in Holdings)
                    {
                        <tr>
                            <td class="td--name">@commodity.Name</td>
                            <td class="text-center">@GameState.Player.Portfolio.Quantity(commodity.Name)</td>
                            <td class="text-center mono">$ @commodity.Price.ToString("F2")</td>
                            <td class="text-center mono">$ @((commodity.Price * GameState.Player.Portfolio.Quantity(commodity.Name)).ToString("F2"))</td>
                            <td class="text-center mono @(commodity.Variation >= 0 ? "text--positive" : "text--negative")">
                                @(commodity.Variation >= 0 ? "+" : "")@((commodity.Variation * 100).ToString("F1"))%
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>

    <!-- Call Options Table ------------------------------- -->
    <section class="portfolio-section">
        <h2 class="section-title">Active Call Options</h2>

        @if (!GameState.Player.Calls.Any())
        {
            <p class="empty-state">No active options. You could buy a call option on the market page!</p>
        }
        else
        {
            <table class="data-table">
                <thead>
                <tr>
                    <th>Underlying</th>
                    <th class="text-center">Strike Price</th>
                    <th class="text-center">Market Price</th>
                    <th class="text-center">Expires</th>
                    <th class="text-center">Payoff</th>
                    <th class="text-center">Status</th>
                    <th></th>
                </tr>
                </thead>
                <tbody>
                @foreach (var option in GameState.Player.Calls)
                {
                    <tr>
                        <td class="td--name">@option.Underlying.Name  @($"(x{option.Quantity})")</td>
                        <td class="text-center mono">$ @option.StrikePrice.ToString("F2")</td>
                        <td class="text-center mono">$ @option.Underlying.Price.ToString("F2")</td>
                        <td class="text-center">T+@option.Expiry</td>
                        <td class="text-center mono @(option.Payoff > 0 ? "text--positive" : "text--negative")">
                            $ @option.Payoff.ToString("F2") 
                        </td>
                        <td class="text-right">
                            <span class="badge @(option.Payoff > 0 ? "badge--itm" : "badge--otm")">
                                @(option.Payoff > 0 ? "In the money" : "Out of the money")
                            </span>
                        </td>
                        <td>
                            @if (option.IsAtExerciceDate && option.Payoff > 0)
                            {
                                <button class="btn btn--exercise btn--small"
                                        @onclick="() => OnExercise(option)">
                                    Exercise
                                </button>
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </section>
    
    
    <!-- Message for call exercise fail/success -->
        @if (_message != null)
        {
            <div class= "exercise-message @(_messageIsError ? "exercise-message--error" : "exercise-message--success")">
                @_message
                </div>
        }

</div>

@code {
    private PlayerStats.FinancialSnapshot _snapshot = null!;
    private string? _message;
    private bool _messageIsError;
    
    private IEnumerable<Commodity> Holdings =>
        GameState.Market.Commodities
            .Where(c => GameState.Player.Portfolio.Quantity(c.Name) > 0);

    private double HoldingsValue =>
        GameState.Player.Stats.CalculatePortfolioValue(GameState.Player, GameState.Market);

    private double NetWorth => _snapshot.NetWorth;
    private double Progression => _snapshot.Progression;
    
    
    
    private async Task OnExercise(Call option)
    {
        bool success = TradingService.ExerciseCall(GameState.Player, option, GameState.Market, GameState.CurrentTurn)!=null;
        if (!success)
        {
            ShowMessage($"You need a ${option.ExerciseCost:F2} net worth to exercise this option.", true);
        }
        else
        {
            await SaveService.SaveGame(GameState);
            ShowMessage($"Exercised call with success. Payoff: ${option.Payoff:F2}" ,false);
            GameState.NotifyStateChanged();
            _snapshot = GameState.Player.Stats.GetSnapshot(GameState.Player, GameState.Market);
        } 
    }
    
    private void ShowMessage(string text, bool isError)
    {
        _message = text;
        _messageIsError = isError;
    }
    
    protected override void OnInitialized()
    {
        _snapshot = GameState.Player.Stats.GetSnapshot(GameState.Player, GameState.Market);
    }
    
    
}

