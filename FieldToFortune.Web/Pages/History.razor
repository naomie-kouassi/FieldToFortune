@page "/history"
@using FieldToFortune.Model
@inject GameState GameState



<div class="history-page">

    <!-- ---- HEADER --------------------------- -->
    <div class="page-header">
        <h1 class="page-title">History</h1>
    </div>

    <!-- ---- TRANSACTION LOG -------------------------- -->
    <section class="portfolio-section">
        <h2 class="section-title">Transaction Log</h2>

        @if (!GameState.Player.Stats.TransactionHistory.Any())
        {
            <p class="empty-state">No transactions yet. Start trading!</p>
        }
        else
        {
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Turn</th>
                        <th>Type</th>
                        <th>Description</th>
                        <th class="text-right">Amount</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var entry in GameState.Player.Stats.TransactionHistory.AsEnumerable().Reverse())
                    {
                        <tr>
                            <td class="mono text--muted">@entry.Turn</td>
                            <td>
                                <span class="badge @GetTypeBadgeClass(entry.Type)">
                                    @entry.Type
                                </span>
                            </td>
                            <td>@entry.Description</td>
                            <td class="text-right mono @(entry.Amount > 0 ? "text--positive" : "text--negative")">
                                $ @(entry.Amount > 0 ? "+" : "-")@Math.Abs(entry.Amount).ToString("F2")
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>

</div>

@code {
    

    private string GetTypeBadgeClass(TransactionType type) => type switch
    {
        TransactionType.Purchase      => "badge--buy",
        TransactionType.Sale     => "badge--sell",
        TransactionType.CallPremium => "badge--call",
        TransactionType.CallExercise => "badge--exercise",
        _                        => ""
    };

}