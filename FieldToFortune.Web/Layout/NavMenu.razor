@implements IDisposable
@using FieldToFortune.Model
@inject GameState GameState
@inject IJSRuntime JSRuntime


<nav class="nav">
    @if (!GameState.FirstGame)
    {
        <div class="nav__brand">
            <span class="nav__logo">F2F</span>
            <div class="nav__brand-text">
                <span class="nav__title">Field to Fortune</span>
                <span class="nav__player">@GameState.Player.Name</span>
            </div>
        </div>

        <div class="nav__links">
            <NavLink class="nav__link" href="market/">
                <span class="nav__icon">◈</span>
                <span>Market</span>
            </NavLink>
            <NavLink class="nav__link" href="portfolio/">
                <span class="nav__icon">◉</span>
                <span>Portfolio</span>
            </NavLink>
            <NavLink class="nav__link" href="history/">
                <span class="nav__icon">◎</span>
                <span>History</span>
            </NavLink>
            <NavLink class="nav__link" href="stats/">
                <span class="nav__icon">❍</span>
                <span>Stats</span>
            </NavLink>
        </div>

        <div class="nav__footer">
            <div class="nav__turn-info">
                <span class="nav__turn-label">Turn</span>
                <span class="nav__turn-value">@Math.Min(GameState.CurrentTurn,GameState.NbTurns) / @GameState.NbTurns</span>
            </div>
            <div class="nav__worth-info">
                <span class="nav__turn-label">Net Worth</span>
                <span class="nav__turn-value @(Snapshot.Progression >=0 ? "text--positive" : "text--negative")">
                    @Snapshot.NetWorth.ToString("F2")$
                </span>
            </div>
            <NavLink class="nav__link nav__link--menu" href="" Match="NavLinkMatch.All">
                <span class="nav__icon">➤</span>
                <span>Menu</span>
            </NavLink>
            
            <button class="theme-toggle" @onclick="GameState.ToggleTheme" title="Toggle theme">
                @(GameState.IsDarkMode ? "☀ Light" : "☾ Dark")
            </button>
        </div>
    }
</nav>



@code {
    private PlayerStats.FinancialSnapshot Snapshot =>
        GameState.Player.Stats.GetSnapshot(GameState.Player, GameState.Market);
    
    protected override void OnInitialized()
    {
        // Subscribe to the event when the component starts
        GameState.OnChange += StateHasChanged;
        GameState.OnThemeChanged += HandleThemeChange;
        _ = ApplyTheme();
    }

    public void Dispose()
    {
        // Unsubscribe when the component is destroyed to prevent memory leaks
        GameState.OnChange -= StateHasChanged;
        GameState.OnThemeChanged -= HandleThemeChange;
    }
    
    private void HandleThemeChange()
    {
        _ = ApplyTheme();
        StateHasChanged(); 
    }
    
    private async Task ApplyTheme()
    {
        // Calls JavaScript function theme.js to switch the colors' CSS variables
        await JSRuntime.InvokeVoidAsync("setTheme", GameState.IsDarkMode ? "dark" : "light");
    }
}